# ============================================================
# Environment variables template
# Copy to .env and fill in the values — NEVER commit .env
# ============================================================

# ── AI / Claude ─────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Tavily search API — https://app.tavily.com/ (free tier available)
TAVILY_API_KEY=tvly-...

# ── Auth / Security ──────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -base64 64
JWT_SECRET=

# JWT expiration (e.g. "15m", "7d", "30d")
JWT_EXPIRES_IN=7d

# Session secret for cookie-based auth (if applicable)
SESSION_SECRET=

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp

# SQLite (for lightweight projects like Syplay)
# DATABASE_URL=file:./dev.db

# ── Cache / Queue ────────────────────────────────────────────
# Redis connection string
REDIS_URL=redis://localhost:6379

# ── GitHub ───────────────────────────────────────────────────
# GitHub personal access token — https://github.com/settings/tokens
# Scopes needed: repo, read:org (for private repos)
GITHUB_TOKEN=ghp_...

# ── NXIO / Project-specific ──────────────────────────────────
# Uncomment and fill for NXIO project

# Ollama (local LLM inference)
# OLLAMA_HOST=http://localhost:11434

# UE5 Remote Control API
# UE5_REMOTE_CONTROL_HOST=host.docker.internal
# UE5_REMOTE_CONTROL_PORT=30010

# Blender addon
# BLENDER_HOST=host.docker.internal
# BLENDER_PORT=9876

# ── External APIs (add as needed) ────────────────────────────
# Stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# Email (Resend, SendGrid, etc.)
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ── App config ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Frontend URL (for CORS, redirect URIs)
APP_URL=http://localhost:3000

# ── Docker / Infrastructure ──────────────────────────────────
# Postgres (for docker-compose.dev.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=myapp_dev
